# Copy this file to .env and fill in your tokens.
# .env is gitignored and never committed.

# Required for all make commands (crawler, notifier, check-consumer)
# Generate with: gh auth token
GITHUB_TOKEN=

# Required for make crawl-agent and make notify-agent
ANTHROPIC_API_KEY=

# Required for make notify and make notify-agent
# PAT for the @driftabot-agent GitHub account (public_repo scope)
DRIFTABOT_TOKEN=
